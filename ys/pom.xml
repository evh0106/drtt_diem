        <project.build>build</project.build>

        <!-- XDoclet Properties -->
        <xdoclet.force>true</xdoclet.force>
        <xdoclet.verbose>true</xdoclet.verbose>
        <xdoclet.version>1.0</xdoclet.version>
        <xdoclet.ejbspec>2.0</xdoclet.ejbspec>
        <xdoclet.template>xdoclet.template</xdoclet.template>

        <!--
        =====================================================
        settings
        =====================================================
        -->
        <finalName>ys</finalName>
    </properties>

    <!-- =================================================================== -->
    <!-- REPOSITORIES - Maven 저장소 설정                                   -->
    <!-- =================================================================== -->
    <repositories>
        <!-- REPOSITORY_PLACEHOLDER -->
        <repository>
            <id>maven-public</id>
            <url>http://10.216.132.161:8081/repository/maven-public</url>
        </repository>
    </repositories>

    <!-- =================================================================== -->
    <!-- BUILD CONFIGURATION - 공통 빌드 설정                               -->
    <!-- =================================================================== -->
    <build>
        <finalName>${finalName}</finalName>
        <sourceDirectory>src</sourceDirectory>

        <plugins>
            <!-- Git Commit Plugin -->
            <plugin>
                <groupId>pl.project13.maven</groupId>
                <artifactId>git-commit-id-plugin</artifactId>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-clean-plugin</artifactId>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <executions>
                    <execution>
                        <id>ejbdoclet</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target>
                                <taskdef name="ejbdoclet" 
                                     classname="xdoclet.modules.ejb.EjbDocletTask" 
                                     classpathref="maven.dependency.classpath" />
                                <echo>+===================================================+</echo>
                                <echo>| ${project.name} EJBDOCLET                         |</echo>
                                <echo>+===================================================+</echo>
                                <mkdir dir="${project.build.directory}/generated-sources" />
                                <mkdir dir="${project.build.outputDirectory}/META-INF" />
                                <ejbdoclet destdir="${project.build.directory}/generated-sources"
                                        mergedir="parent-fake-to-debug"
                                        excludedtags="@version,@author,@todo"
                                        addedtags="@author 일관제철 정보화 시스템,@version ${xdoclet.version},@copyright 현대제철"
                                        ejbspec="${xdoclet.ejbspec}"
                                        force="${xdoclet.force}"
                                        verbose="${xdoclet.verbose}" >
                                    <fileset dir="${project.build.sourceDirectory}">
                                        <include name="**/*EJB*.java" />
                                    </fileset>

                                    <remoteinterface templateFile="../lib/${xdoclet.template}/ini.remote.xdt" />
                                    <homeinterface templateFile="../lib/${xdoclet.template}/ini.home.xdt" />
                                    <deploymentdescriptor destdir="${project.build.outputDirectory}/META-INF"
                                                            xmlencoding="MS949"
                                                            validatexml="true"
                                                            mergedir="fake-to-debug" />

                                    <weblogic version="8.1"
                                                xmlencoding="MS949"
                                                destdir="${project.build.outputDirectory}/META-INF"
                                                validatexml="true"
                                                mergedir="fake-to-debug"
                                                createtables="Disabled" />
                                </ejbdoclet>
                            </target>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>build-helper-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <id>add-gen-sources</id>
                        <phase>process-sources</phase>
                        <goals>
                            <goal>add-source</goal>
                        </goals>
                        <configuration>
                            <sources>
                                <source>${project.build.directory}/generated-sources</source>
                            </sources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
            </plugin>

            <!-- Maven JAR Plugin -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <configuration>
                    <finalName>${project.build.finalName}</finalName>
                    <archive>
                        <manifest>
                            <addClasspath>false</addClasspath>
                            <addDefaultImplementationEntries>true</addDefaultImplementationEntries>
                            <addDefaultSpecificationEntries>true</addDefaultSpecificationEntries>
                        </manifest>
                        <manifestEntries>
                            <Build-Time>${maven.build.timestamp}</Build-Time>
                            <Build-Time>${maven.build.timestamp}</Build-Time>
                            <Git-Commit-Id>${git.commit.id}</Git-Commit-Id>
                            <Git-Commit-Id-Abbrev>${git.commit.id.abbrev}</Git-Commit-Id-Abbrev>
                            <Git-Commit-Time>${git.commit.time}</Git-Commit-Time>
                            <Git-Commit-Message-Short>${git.commit.message.short}</Git-Commit-Message-Short>
                            <Git-Branch>${git.branch}</Git-Branch>
                        </manifestEntries>
                        <compress>true</compress>
                    </archive>
                </configuration>
                <executions>
                    <!-- 기본 JAR 생성 (Skip) -->
                    <execution>
                        <id>default-jar</id>
                        <phase>none</phase>
                        <goals>
                            <goal>jar</goal>
                        </goals>
                    </execution>
                    <!-- EJB JAR 생성 -->
                    <execution>
                        <id>ejb-jar</id>
                        <phase>package</phase>
                        <goals>
                            <goal>jar</goal>
                        </goals>
                        <configuration>
                            <finalName>${project.build.finalName}-ejb</finalName>
                            <includes>
                                <include>META-INF/*.xml</include>
                                <include>**/*EJB*.class</include>
                            </includes>
                        </configuration>
                    </execution>
                    <!-- 일반 JAR 생성 -->
                    <execution>
                        <id>main-jar</id>
                        <phase>package</phase>
                        <goals>
                            <goal>jar</goal>
                        </goals>
                        <configuration>
                            <finalName>${project.build.finalName}</finalName>
                            <includes>
                                <include>**/*.class</include>
                            </includes>
                            <excludes>
                                <exclude>META-INF/*.xml</exclude>
                            </excludes>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- EJB/JAR Install Plugin (로컬 배포) -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-install-plugin</artifactId>
                <executions>
                    <execution>
                        <id>install-ejb</id>
                        <phase>install</phase>
                        <goals>
                            <goal>install-file</goal>
                        </goals>
                        <configuration>
                            <file>${project.build.directory}/${project.build.finalName}-ejb.jar</file>
                            <groupId>${project.groupId}.ejb</groupId>
                            <artifactId>${project.artifactId}-ejb</artifactId>
                            <version>${project.version}</version>
                            <generatePom>false</generatePom>
                            <pomFile>${project.file}</pomFile> 
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- EJB/JAR Deploy Plugin (원격 배포) -->
            <!--
            !! Nexus 권한에 따라 CI 단계 자동 관리 특정 사용자에게만 배포 권한 부여
            COMMENT: CI 단계 자동 관리 추천
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-deploy-plugin</artifactId>
                <executions>
                    <execution>
                        <id>deploy-ejb</id>
                        <phase>deploy</phase>
                        <goals>
                            <goal>deploy-file</goal>
                        </goals>
                        <configuration>
                            <file>${project.build.directory}/${project.build.finalName}-ejb.jar</file>
                            <groupId>${project.groupId}.ejb</groupId>
                            <artifactId>${project.artifactId}-ejb</artifactId>
                            <version>${project.version}</version>
                            <repositoryId>${hds.dist.snapshot.id}</repositoryId>
                            <url>${hds.dist.snapshot.url}</url>
                            <generatePom>false</generatePom>
                            <pomFile>${project.file}</pomFile>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>


