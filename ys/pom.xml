        <!-- TODO: 빌드 인코딩 확인. -->
        <project.build.sourceEncoding>MS949</project.build.sourceEncoding>
        
        <!-- Java Compiler Properties -->
        <maven.compiler.debug>true</maven.compiler.debug>
        <maven.compiler.showDeprecation>false</maven.compiler.showDeprecation>

        <!-- Project Directory Properties -->
        <project.lib>lib</project.lib>
